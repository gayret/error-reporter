{
  "name": "@safagayret/error-reporter",
  "version": "1.0.0",
  "description": "A lightweight, configurable browser-side error reporter. Captures console logs, network requests and a screenshot, then packages everything into a ZIP — either downloaded locally or uploaded to your endpoint.",
  "main": "src/index.js",
  "bin": {
    "error-reporter": "bin/init.js"
  },
  "scripts": {
    "init": "node bin/init.js"
  },
  "files": [
    "src",
    "bin",
    "template",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "error-reporter",
    "bug-report",
    "debugging",
    "screenshot",
    "network-log",
    "console-log",
    "browser"
  ],
  "author": "Safa Gayret",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gayret/error-reporter.git"
  },
  "homepage": "https://github.com/gayret/error-reporter",
  "bugs": {
    "url": "https://github.com/gayret/error-reporter/issues"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1"
  }
}
